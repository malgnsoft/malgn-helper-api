{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "malgn-helper-api",
  "account_id": "d2b8c5524b7259214fa302f1fecb4ad6",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Smart Placement — backend(OpenAI 등) 가까운 colo에서 Worker 실행.
  // 한국 colo에서 OpenAI 호출 시 region 차단되는 문제를 자동 우회 (학습 후 미국 colo로 이동).
  "placement": { "mode": "smart" },

  "r2_buckets": [
    { "binding": "R2", "bucket_name": "malgn-helper-files" }
  ],

  "hyperdrive": [
    { "binding": "HYPERDRIVE", "id": "aea36082dfd84125a0da2063d5b8e5e0" }
  ],

  // Workers AI binding — Cloudflare 자체 catalog (region 제한 없음, $10 크레딧 사용).
  // openai/o4-mini 등 OpenAI partner 모델도 binding으로 호출 가능.
  "ai": { "binding": "AI" },

  // Cloudflare Rate Limiting binding (무상태·무료, KV/D1 불필요).
  // PMS LLM generate 4종에 적용 — key(route path + IP) 기준.
  // limit/period 는 계정의 rate-limit 한도 단위(period 는 10 또는 60 만 허용).
  // 분당 12회 = 프로젝트/포스트별·IP별 generate 상한(LLM 비용 남용 방어).
  "ratelimits": [
    {
      "name": "RL_LLM",
      "namespace_id": "1001",
      "simple": { "limit": 12, "period": 60 }
    }
  ],

  "vars": {
    // Cloudflare AI Gateway compat endpoint (비BYOK 모드).
    // Cloudflare가 자체 credit으로 OpenAI 호출 → datacenter IP region 차단 우회.
    // Provider(BYOK) 등록은 삭제하고 Gateway 크레딧 충전으로 운영.
    "AI_GATEWAY_URL": "https://gateway.ai.cloudflare.com/v1/d2b8c5524b7259214fa302f1fecb4ad6/malgn-helper2/compat",
    "LLM_MODEL_DEFAULT": "openai/gpt-4.1-mini",
    "LLM_MODEL_PREMIUM": "openai/gpt-4.1-mini",

    // PMS 자산(/data/..) 절대화 base — 표준답변 저장 시 이미지 경로를 도메인 포함 절대 URL로 정규화.
    "PMS_ASSET_BASE": "https://ppm.malgn.co.kr",

    // 서비스 토큰 하드 차단 플래그. PMS 프록시 전환 검증 후 "1"로 올린다.
    // "0"(또는 미설정): secret 설정+토큰 불일치도 통과(관찰 모드).
    "SERVICE_TOKEN_ENFORCE": "0",

    // Cloudflare Access JWT 검증용 — /auth/access-exchange 가드.
    // CF_ACCESS_AUD 는 Cloudflare Zero Trust → Access Applications → Overview → AUD Tag 값.
    "CF_ACCESS_TEAM_DOMAIN": "https://malgnsoft.cloudflareaccess.com",
    "CF_ACCESS_AUD": "REPLACE_WITH_ACCESS_APPLICATION_AUD_TAG"
  }

  // PMS_SERVICE_TOKEN / OPENAI_API_KEY / JWT_SECRET / AI_GATEWAY_TOKEN 은
  // wrangler secret 으로 등록 (코드·git 노출 금지):
  //   wrangler secret put PMS_SERVICE_TOKEN
}
